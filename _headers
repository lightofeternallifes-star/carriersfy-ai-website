/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://fonts.googleapis.com https://challenges.cloudflare.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self' https://unpkg.com; frame-src https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self'

/api/*
  Access-Control-Allow-Origin: https://carriersfy.ai
  Access-Control-Allow-Methods: GET, POST, OPTIONS
  Access-Control-Allow-Headers: Content-Type

/OMEGA/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store, no-cache

/config/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store, no-cache

/docs/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store, no-cache

/pages/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store, no-cache

/codex/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store, no-cache
