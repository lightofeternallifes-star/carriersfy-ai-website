# Enterprise Memory OS — internal only, never serve publicly
OMEGA/

# Environment variables — never commit
.env
.env.*
!.env.example

# Node / development artifacts
node_modules/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
.cache/
.parcel-cache/

# Sofia Knowledge Importer — generated artifacts (rebuild via: cd knowledge && npm run import)
knowledge/output/knowledge.json
knowledge/output/search-index.json
knowledge/output/embeddings.ndjson

# OS artifacts
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE artifacts
.vscode/settings.json
.idea/
*.iml

# Cloudflare Wrangler
.wrangler/
*/.wrangler/
# Root-level wrangler.toml only — sofia/wrangler.toml is intentionally tracked
/wrangler.toml

# Local dev secrets
.dev.vars

# Logs
*.log
